generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum MarketplaceType {
  WILDBERRIES
  OZON
  YANDEX_MARKET
  AVITO
  OTHER
}

enum OrderStatus {
  NEW
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum ReviewStatus {
  NEW
  ANSWERED
  ARCHIVED
}

enum AIRecommendationType {
  PRICE
  STOCK
  SEO
  REVIEW_REPLY
  GENERAL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketplaces Marketplace[]
  aiLogs       AIAssistantLog[]

  @@map("users")
}

model Marketplace {
  id        String          @id @default(uuid())
  name      String
  type      MarketplaceType
  apiKey    String?
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]

  @@map("marketplaces")
}

model Product {
  id            String   @id @default(uuid())
  marketplaceId String
  title         String
  sku           String
  price         Decimal  @db.Decimal(10, 2)
  stock         Int      @default(0)
  rating        Decimal? @db.Decimal(3, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  marketplace       Marketplace        @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  orders            Order[]
  reviews           Review[]
  analytics         ProductAnalytics[]
  aiRecommendations AIRecommendation[]

  @@unique([marketplaceId, sku])
  @@map("products")
}

model Order {
  id            String      @id @default(uuid())
  marketplaceId String
  productId     String
  externalId    String
  status        OrderStatus @default(NEW)
  quantity      Int
  totalPrice    Decimal     @db.Decimal(10, 2)
  orderedAt     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([marketplaceId, externalId])
  @@map("orders")
}

model Review {
  id         String       @id @default(uuid())
  productId  String
  authorName String
  rating     Int
  text       String
  status     ReviewStatus @default(NEW)
  answerText String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ProductAnalytics {
  id             String   @id @default(uuid())
  productId      String
  date           DateTime
  views          Int      @default(0)
  ordersCount    Int      @default(0)
  revenue        Decimal  @db.Decimal(10, 2)
  conversionRate Decimal  @db.Decimal(5, 2)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@map("product_analytics")
}

model AIRecommendation {
  id        String               @id @default(uuid())
  productId String
  type      AIRecommendationType
  title     String
  content   String
  isApplied Boolean              @default(false)
  createdAt DateTime             @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("ai_recommendations")
}

model AIAssistantLog {
  id        String   @id @default(uuid())
  userId    String
  prompt    String
  response  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_assistant_logs")
}
